; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited if needed.

config_version=5

[application]

config/name="Space Explorer RT"
config/description="A mobile 2D real-time space exploration game"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.4")

[autoload]

GameState="*res://scripts/game_state.gd"
SaveManager="*res://scripts/save_manager.gd"
WorldData="*res://scripts/world_data.gd"

[display]

window/size/viewport_width=390
window/size/viewport_height=844
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="mobile"
